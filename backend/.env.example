# AWS Configuration
AWS_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3
S3_BUCKET_USER_DATA=prepai-user-data-2026
S3_BUCKET_KNOWLEDGE_BASE=prepai-knowledge-base-2026

# Bedrock
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
BEDROCK_KNOWLEDGE_BASE_ID=

# STT / TTS
DEEPGRAM_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Lambda
LAMBDA_CODE_EXECUTOR=prepai-code-executor
LAMBDA_CV_ANALYZER=prepai-cv-analyzer
LAMBDA_PERFORMANCE_EVALUATOR=prepai-performance-evaluator

# Supabase — get from https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # secret — never expose in frontend
SUPABASE_JWT_SECRET=                      # Project Settings > API > JWT Settings > JWT Secret

# Supabase PostgreSQL — get from Project Settings > Database > Connection string
# Use the "Session mode" pooler URI (port 5432) for long-lived asyncpg connections
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Server
CORS_ORIGINS=http://localhost:3000,https://intervyu.io,https://www.intervyu.io
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=production
